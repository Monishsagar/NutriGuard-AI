# Supabase
# Get these from your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini AI
# Get this from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key

# Gmail setup for sending email alerts
# Use your Gmail address and generate a 16-character App Password
# Instructions: https://support.google.com/accounts/answer/185833
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# Application URLs (Optional, defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
